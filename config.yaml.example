# Copy this to config.yaml and fill in your values

kasa:
  # Leave empty to auto-discover on the network.
  # You can also pin specific devices:
  devices:
    # - alias: "Desk Lamp"
    #   host: "192.168.1.50"
    # - alias: "3D Printer"
    #   host: "192.168.1.51"

aidot:
  # AiDot smart bulbs — uses python-aidot for local LAN control.
  # Credentials are your AiDot app login. Discovery and control happen
  # locally after the initial login; no cloud required at runtime.
  username: "your_aidot_email@example.com"
  password: "your_aidot_password"
  country_code: "US"  # US, EU, or JP
  groups:
    - name: "Living Room"
      devices:
        - "Disco1"
        - "Disco2"

ecoflow:
  # Cloud mode — get API keys from developer.ecoflow.com (free account).
  # Easiest setup: no local broker or DNS changes needed.
  mode: "cloud"
  serial_number: "EFDELTA..."   # sticker on the unit
  access_key: "your_access_key"
  secret_key: "your_secret_key"

  # Local MQTT mode — no internet required at runtime, but needs Mosquitto
  # installed and mqtt.ecoflow.com DNS-redirected to this machine.
  # mode: "mqtt_local"
  # mqtt_host: "127.0.0.1"
  # mqtt_port: 1883

arduino_ir:
  # ── Choose one mode ──────────────────────────────────────────────────────
  #
  # mode: serial   → Arduino Uno (or clone) over USB, sketch: ir_blaster_uno.ino
  #   serial_port: "/dev/ttyACM0"   # genuine Arduino Uno
  #   serial_port: "/dev/ttyUSB0"   # clone with CH340 chip (most common)
  #   baud_rate: 9600
  #
  # mode: wifi     → ESP32/ESP8266 over WiFi, sketch: ir_blaster.ino
  #   host: "192.168.1.70"
  #   port: 80
  #
  # To find your serial port:
  #   ls /dev/tty{ACM,USB}*          (Linux)
  #   ls /dev/cu.usbserial-*         (macOS)
  #   Device Manager → COM ports     (Windows)

  mode: serial
  serial_port: "/dev/ttyUSB0"
  baud_rate: 9600

  # ── IR command codes (hex, protocol defined per-device) ──────────────────
  # These are starting points — use the IR Learner in the UI to capture yours.
  # Predefined IR command codes (hex, NEC format by default)
  # These are starting points — use /api/ir/learn to capture your actual codes
  devices:
    projector:
      name: "ViewSonic Projector"
      protocol: "NEC"
      commands:
        power:       "0x807F817E"
        menu:        "0x807FD12E"
        up:          "0x807F8D72"
        down:        "0x807F8D73"
        left:        "0x807F8D74"
        right:       "0x807F8D75"
        enter:       "0x807F916E"
        source:      "0x807FC13E"
        volume_up:   "0x807F49B6"
        volume_down: "0x807FC936"
        mute:        "0x807F09F6"
        keystone_p:  "0x807F55AA"
        keystone_n:  "0x807FD52A"
    soundbar:
      name: "Vizio Soundbar"
      protocol: "NEC"
      commands:
        power:       "0x20DF08F7"
        volume_up:   "0x20DF40BF"
        volume_down: "0x20DFC03F"
        mute:        "0x20DF906F"
        input:       "0x20DF0AF5"
        bluetooth:   "0x20DF42BD"
        optical:     "0x20DFC23D"
        bass_up:     "0x20DF22DD"
        bass_down:   "0x20DFA25D"
    ceiling_fan:
      name: "Ceiling Fan"
      type: rf          # RF device — uses RFSEND/RFLEARN serial commands
      protocol: 1       # RCSwitch protocol (1 = standard OOK, covers most 433 MHz remotes)
      bit_length: 24    # Hunter TX45 uses 24-bit codes
      # Use the RF Learner in the UI (Display section) to capture these.
      # Point the TX45 remote at the XY-MK-5V receiver and press each button.
      commands:
        fan_off:    "0x000000"   # replace with learned value
        fan_low:    "0x000000"
        fan_medium: "0x000000"
        fan_high:   "0x000000"
        light:      "0x000000"
        direction:  "0x000000"

roku:
  # Leave host empty to auto-discover via SSDP.
  # host: "192.168.1.80"
