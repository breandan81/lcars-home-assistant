# Copy this to config.yaml and fill in your values

kasa:
  # Leave empty to auto-discover on the network.
  # You can also pin specific devices:
  devices:
    # - alias: "Desk Lamp"
    #   host: "192.168.1.50"
    # - alias: "3D Printer"
    #   host: "192.168.1.51"

tuya:
  # AiDot bulbs are Tuya-based.
  # Run: python3 -m tinytuya scan   to find your device IDs and IPs.
  # Get local_key from the Tuya IoT Platform (see README).
  devices:
    # - id: "xxxxxxxxxxxxxxxxxxxxxxxx"
    #   ip: "192.168.1.60"
    #   key: "xxxxxxxxxxxxxxxx"
    #   version: "3.3"
    #   name: "Bedroom Bulb"
    # - id: "yyyyyyyyyyyyyyyyyyyyyyyy"
    #   ip: "192.168.1.61"
    #   key: "yyyyyyyyyyyyyyyy"
    #   version: "3.3"
    #   name: "Living Room Bulb"

ecoflow:
  # Local MQTT mode: run Mosquitto locally and redirect the Wave 2 to it.
  # See README for full setup. The SN is on the sticker on your unit.
  mode: "mqtt_local"          # "mqtt_local" or "cloud"
  serial_number: "EFDELTA..."  # Your Wave 2 serial number
  mqtt_host: "127.0.0.1"
  mqtt_port: 1883

  # Only needed if mode: "cloud"
  # api_key: "your_access_key"
  # api_secret: "your_secret_key"

arduino_ir:
  # ── Choose one mode ──────────────────────────────────────────────────────
  #
  # mode: serial   → Arduino Uno (or clone) over USB, sketch: ir_blaster_uno.ino
  #   serial_port: "/dev/ttyACM0"   # genuine Arduino Uno
  #   serial_port: "/dev/ttyUSB0"   # clone with CH340 chip (most common)
  #   baud_rate: 9600
  #
  # mode: wifi     → ESP32/ESP8266 over WiFi, sketch: ir_blaster.ino
  #   host: "192.168.1.70"
  #   port: 80
  #
  # To find your serial port:
  #   ls /dev/tty{ACM,USB}*          (Linux)
  #   ls /dev/cu.usbserial-*         (macOS)
  #   Device Manager → COM ports     (Windows)

  mode: serial
  serial_port: "/dev/ttyUSB0"
  baud_rate: 9600

  # ── IR command codes (hex, protocol defined per-device) ──────────────────
  # These are starting points — use the IR Learner in the UI to capture yours.
  # Predefined IR command codes (hex, NEC format by default)
  # These are starting points — use /api/ir/learn to capture your actual codes
  devices:
    projector:
      name: "ViewSonic Projector"
      protocol: "NEC"
      commands:
        power:       "0x807F817E"
        menu:        "0x807FD12E"
        up:          "0x807F8D72"
        down:        "0x807F8D73"
        left:        "0x807F8D74"
        right:       "0x807F8D75"
        enter:       "0x807F916E"
        source:      "0x807FC13E"
        volume_up:   "0x807F49B6"
        volume_down: "0x807FC936"
        mute:        "0x807F09F6"
        keystone_p:  "0x807F55AA"
        keystone_n:  "0x807FD52A"
    soundbar:
      name: "Vizio Soundbar"
      protocol: "NEC"
      commands:
        power:       "0x20DF08F7"
        volume_up:   "0x20DF40BF"
        volume_down: "0x20DFC03F"
        mute:        "0x20DF906F"
        input:       "0x20DF0AF5"
        bluetooth:   "0x20DF42BD"
        optical:     "0x20DFC23D"
        bass_up:     "0x20DF22DD"
        bass_down:   "0x20DFA25D"
    ceiling_fan:
      name: "Ceiling Fan"
      type: rf          # RF device — uses RFSEND/RFLEARN serial commands
      protocol: 1       # RCSwitch protocol (1 = standard OOK, covers most 433 MHz remotes)
      bit_length: 24    # Hunter TX45 uses 24-bit codes
      # Use the RF Learner in the UI (Display section) to capture these.
      # Point the TX45 remote at the XY-MK-5V receiver and press each button.
      commands:
        fan_off:    "0x000000"   # replace with learned value
        fan_low:    "0x000000"
        fan_medium: "0x000000"
        fan_high:   "0x000000"
        light:      "0x000000"
        direction:  "0x000000"

roku:
  # Leave host empty to auto-discover via SSDP.
  # host: "192.168.1.80"
